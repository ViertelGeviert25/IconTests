<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
</configuration>






  public static class LoggerExtensions
  {
      private static readonly Dictionary<string, string> LoggerSuccessProperty
          = new() { { "tag", "SUCCESS" } };

      public static void Success(this Logger logger, string messageText)
      {
          // logger name is the caller type (not this extension class!)
          var loggerName = new StackTrace()
              .GetFrame(1)?.GetMethod()?.ReflectedType?.ToString() ?? string.Empty;
          logger.Info(messageText, loggerName, LoggerSuccessProperty);
      }
  }
    public class LogEntry
    {
        public int Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string? Message { get; set; }
        public required EDebugLevel Level { get; set; }

        public required string Logger { get; set; }

        public override string ToString()
        {
            return $"[{Timestamp}] {Level}: {Message}";
        }
    }



using log4net;
using log4net.Appender;
using log4net.Repository.Hierarchy;
using Microsoft.Data.Sqlite;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata;

namespace LoggerSandbox
{
    public class DatabaseContext : DbContext
    {
        public DbSet<LogEntry>? Logs { get; set; }

        private const string DB_FILE_NAME = "logs.db";
        private readonly string _dbFilePath = string.Empty;

        protected override void OnConfiguring(DbContextOptionsBuilder optionsBuilder)
        {
            var sqliteConnStrinBuilder = new SqliteConnectionStringBuilder()
            {
                DataSource = _dbFilePath
            };
            var connStr = sqliteConnStrinBuilder.ToString();
            var conn = new SqliteConnection(connStr);
            optionsBuilder.UseSqlite(conn);
        }

        public SqliteConnection SqliteConnection
        {
            get
            {
                return (SqliteConnection)Database.GetDbConnection();
            }
        }

        public void ConfigureAdoNetAppender()
        {
            var hierarchy = (Hierarchy)LogManager.GetRepository();
            var appenders = hierarchy.GetAppenders().OfType<AdoNetAppender>();
            foreach (var appender in appenders)
            {
                appender.ConnectionType = $"{typeof(SqliteConnection)}, {typeof(SqliteConnection).Namespace}";
                appender.ConnectionString = SqliteConnection.ConnectionString;
                IEntityType logEntryType = Model.FindEntityType(typeof(LogEntry))
                    ?? throw new NullReferenceException($"Entity type '{nameof(LogEntry)}' not found")!;
                appender.CommandText =
                    $"INSERT INTO {logEntryType?.GetTableName()} " +
                    $"({logEntryType!.GetProperty(nameof(LogEntry.Timestamp)).GetColumnName()}, " +
                    $"{logEntryType.GetProperty(nameof(LogEntry.Level)).GetColumnName()}, " +
                    $"{logEntryType.GetProperty(nameof(LogEntry.Logger)).GetColumnName()}, " +
                    $"{logEntryType.GetProperty(nameof(LogEntry.Message)).GetColumnName()}) " +
                    $"VALUES (@Date, @Level, @Logger, @Message)";

                appender.ActivateOptions();
            }
        }

        protected override void OnModelCreating(ModelBuilder modelBuilder)
        {
            modelBuilder.Entity<LogEntry>().ToTable("LOGS").HasKey(l => l.Id);
            modelBuilder.Entity<LogEntry>().Property(p => p.Id).HasColumnName("LOG_ID").ValueGeneratedOnAdd();
            modelBuilder.Entity<LogEntry>().Property(p => p.Message).HasColumnName("LOG_MESSAGE");
            modelBuilder.Entity<LogEntry>().Property(p => p.Timestamp).HasColumnName("LOG_DATE");
            modelBuilder.Entity<LogEntry>().Property(p => p.Level).HasColumnName("LOG_LEVEL");
            modelBuilder.Entity<LogEntry>().Property(p => p.Logger).HasColumnName("LOG_LOGGER");

            base.OnModelCreating(modelBuilder);
        }


        public DatabaseContext(string paramDbPath) : base()
        {
            _dbFilePath = paramDbPath;
            Database.EnsureCreated();

            //var sql = File.ReadAllText("app_core_tables.sql");
            //Database.ExecuteSqlRaw(sql);
        }

        public static void Initialize(string paramDirName)
        {
            Logging.Logger.Instance.Init();

            var dbFilePath = Path.Combine(paramDirName, DB_FILE_NAME);
            var dbContext = new DatabaseContext(dbFilePath);
            dbContext.ConfigureAdoNetAppender();
            dbContext.Dispose();
        }

        public void EmptyLogs()
        {
            Logs?.RemoveRange(Logs);
            SaveChanges();
        }
    }
}
